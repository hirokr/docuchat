# Application
APP_API_KEY=change-me-to-a-secure-random-string
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database — local or Neon (paste Neon connection string as-is; auto-converted for asyncpg)
DATABASE_URL=postgresql+asyncpg://docuchat:docuchat@localhost:5432/docuchat
# Neon example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Groq (chat / LLM)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=60

# OpenRouter (embeddings only)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_TIMEOUT_SECONDS=60

# Pinecone
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=docuchat
PINECONE_TIMEOUT_SECONDS=30

# Upload limits
MAX_PDF_SIZE_BYTES=10485760
MAX_DOCUMENTS_PER_SESSION=3
UPLOAD_DIR=uploads

# RAG tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
MEMORY_MESSAGE_LIMIT=10

# WebSocket
WEBSOCKET_TIMEOUT_SECONDS=300

# CORS (comma-separated origins, use * for dev)
CORS_ORIGINS=["*"]
